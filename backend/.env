# Comentário de documentação JamesBar
# Arquivo: backend/.env
# Função: Arquivo de configuração do projeto JamesBar.

# ==================================================
# BANCO DE DADOS
# ==================================================

DB_HOST=localhost
DB_PORT=3306
DB_NAME_CORE=db_core
DB_USER=root
DB_PASS=

# ==================================================
# BANCO LISTAS VIP
# ==================================================

DB_VIP_NAME=db_listas_vip

# ==================================================
# APLICAÇÃO
# ==================================================

APP_NAME=JamesBar
APP_ENV=development
APP_DEBUG=true

# ==================================================
# SESSÃO
# ==================================================

SESSION_TIMEOUT=300

# ==================================================
# LOGIN
# ==================================================

MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_MINUTES=10

# ==================================================
# MFA
# ==================================================

MFA_ENABLED=true

# ==================================================
# CRIPTOGRAFIA
# ==================================================

APP_KEY=TroquePorUmaChaveGrandeAleatoriaCom32Caracteres